# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
# DOMÍNIO: Quando tiveres domínio, coloca aqui (ex: meudominio.pt,www.meudominio.pt)
# Isto é necessário para o Django aceitar pedidos do teu domínio.
# Também actualiza o Caddyfile e settings.py.
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
# CSRF_TRUSTED_ORIGINS é gerado automaticamente a partir de ALLOWED_HOSTS (https://)

# MariaDB
DB_NAME=lista_compras
DB_USER=lista_user
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=change-me-root-password

# Email (SMTP para recuperação de palavra-passe)
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=geral@listaisto.pt
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL=ListaIsto <geral@listaisto.pt>
